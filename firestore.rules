rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is coach or admin
    function isCoachOrAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin'] ||
         request.auth.token.email == 'johnmakumi106@gmail.com');
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isCoachOrAdmin());
      allow delete: if isCoachOrAdmin();
    }
    
    // Courts collection
    match /courts/{courtId} {
      allow read: if isAuthenticated();
      allow write: if isCoachOrAdmin();
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (resource.data.user_id == request.auth.uid || isCoachOrAdmin());
      allow delete: if isAuthenticated() && 
        (resource.data.user_id == request.auth.uid || isCoachOrAdmin());
    }
    
    // Tournaments collection
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if isCoachOrAdmin();
    }
    
    // Tournament registrations
    match /tournament_registrations/{registrationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (resource.data.user_id == request.auth.uid || isCoachOrAdmin());
      allow delete: if isCoachOrAdmin();
    }
    
    // Matches collection
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow write: if isCoachOrAdmin();
    }
    
    // Messages collection
    match /messages/{messageId} {
      allow read: if isAuthenticated() && 
        (resource.data.sender_id == request.auth.uid || 
         resource.data.receiver_id == request.auth.uid ||
         isCoachOrAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (resource.data.receiver_id == request.auth.uid || isCoachOrAdmin());
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }
    
    // Training sessions
    match /training_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isCoachOrAdmin();
    }
    
    // Announcements
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isCoachOrAdmin();
      allow update: if isAuthenticated() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['read_by', 'updated_at']) &&
        request.resource.data.read_by is list &&
        (resource.data.read_by == null || request.resource.data.read_by.hasAll(resource.data.read_by)) &&
        request.resource.data.read_by.hasAny([request.auth.uid]);
    }
    
    // Player statistics
    match /player_statistics/{playerId} {
      allow read: if isAuthenticated();
      allow write: if isCoachOrAdmin();
    }
    
    // Clubs
    match /clubs/{clubId} {
      allow read: if isAuthenticated();
      allow write: if isCoachOrAdmin();
    }
  }
}
